{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dev: localhost (API + web)",
      "type": "shell",
      "command": "pnpm dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "valuation-localhost",
        "pattern": { "regexp": "^$", "file": 1, "location": 1, "message": 2 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Server listening|Local:\\s+http)"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      }
    },
    {
      "label": "Dev: API only",
      "type": "shell",
      "command": "pnpm dev:api",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "valuation-api",
        "pattern": { "regexp": "^$", "file": 1, "location": 1, "message": 2 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Server listening"
        }
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      }
    },
    {
      "label": "Dev: web only",
      "type": "shell",
      "command": "pnpm dev:app",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "valuation-web",
        "pattern": { "regexp": "^$", "file": 1, "location": 1, "message": 2 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:\\s+http"
        }
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      }
    }
  ]
}
