# Copy to ".env" at the repo root (or export in your shell).
# Quick local stack: from repo root run `pnpm install` then `pnpm dev` (API on :3001 + Vite on :5173 with /api proxy).

# Required for the API (@workspace/db). Optional in .env.local for overrides.
# Railway (local dev on your machine): paste the *public* Postgres URL here (e.g. DATABASE_PUBLIC_URL).
# The default DATABASE_URL from Railway often uses host *.railway.internal and only works inside Railway.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/valyoued

# API HTTP port — defaults to 3001 if unset (matches Vite's /api dev proxy).


# --- Web (Vite / Vercel) ---
# Required for real Clerk. Root `.env.development` sets stub auth for local `vite`; without env files,
# Vite still enables stub in development when no publishable key (use VITE_AUTH_STUB_MODE=0 to opt out).
VITE_CLERK_PUBLISHABLE_KEY=

# Local dev: Vite proxies /api → this URL when VITE_API_ORIGIN is unset (Express default below).
# VITE_DEV_API_PROXY=http://127.0.0.1:3001


# When API is NOT same-origin as the UI (typical: Vercel frontend + Railway/Fly/Render API):
# VITE_API_ORIGIN=https://your-api.example.com

# Optional Clerk proxy (Replit / custom backends):
# VITE_CLERK_PROXY_URL=

# --- API server (Express, artifacts/api-server) ---
# Must match the Clerk app used by VITE_CLERK_PUBLISHABLE_KEY:
# CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# Operations dashboard (/api/admin/*). Comma-separated Clerk user IDs (`user_...` from Clerk Dashboard → Users).
# With AUTH_STUB_MODE=1 locally, admins are allowed even if this is unset. In production always set this explicitly.
# ADMIN_USER_IDS=user_2abc...,user_2def...

# --- LLM (`@workspace/llm`) — pick provider ---
# LLM_PROVIDER=anthropic
# Optional override for any vendor (such as claude-sonnet-4-5, gpt-4o):
# LLM_MODEL=

# Anthropic (default). Replit: AI Integrations env vars. Local: public API:
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=
# Aliases:
# ANTHROPIC_BASE_URL=
# ANTHROPIC_API_KEY=

# OpenAI — set LLM_PROVIDER=openai
# OPENAI_API_KEY=
# Optional (Azure / proxies):
# OPENAI_BASE_URL=

# --- Local dev stubs (never enable in public production without safeguards) ---
# Auth: skip Clerk on API + treat UI as signed-in (fixed user id on server).
# VITE_AUTH_STUB_MODE=1
# AUTH_STUB_MODE=1
# AUTH_STUB_USER_ID=dev-stub-user
# Optional: pretend subscription tier when using auth stub (free | pro):
# AUTH_STUB_BILLING_TIER=free

# Stripe: mock checkout / portal / webhook (returns stub URLs; no Stripe keys needed).
# STRIPE_STUB_MODE=1

# Escape hatch if you truly need stubs with NODE_ENV=production (unsafe):
# ALLOW_INSECURE_DEV_STUBS=1

# --- FX (USD normalization for portfolio + /estimates/stats) ---
# When enabled, the API fetches ECB rates via Frankfurter, merges with static fallbacks for missing currencies, and caches the result.
# FX_LIVE_ENABLED=1
# Optional: override Frankfurter URL (default https://api.frankfurter.app/v1/latest?from=USD)
# FRANKFURTER_URL=
# Cache TTL in ms for live FX (default 6 hours)
# FX_CACHE_TTL_MS=

# API listen port — optional; the server defaults to 3001 if unset (same as Vite /api proxy target).
# PORT=8080
